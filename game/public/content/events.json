[
    {
        "id": "event_art_market_gossip",
        "category": "social",
        "title": "Overheard in Chelsea",
        "requirements": {},
        "steps": [
            {
                "type": "narrative",
                "text": "You overhear two well-dressed collectors arguing outside a pristine white-cube gallery.",
                "characterId": "narrator"
            },
            {
                "type": "choice",
                "text": "They seem to be debating the value of a new digital artist. What do you do?",
                "choices": [
                    {
                        "label": "Eavesdrop carefully.",
                        "nextStep": 2,
                        "statChange": {
                            "intel": 1
                        }
                    },
                    {
                        "label": "Interrupt and offer your opinion.",
                        "nextStep": 3,
                        "statChange": {
                            "audacity": 1
                        },
                        "requires": {
                            "audacity": 5
                        }
                    }
                ]
            },
            {
                "type": "narrative",
                "text": "You catch a few names and upcoming exhibition dates. Useful intel.",
                "characterId": "narrator",
                "isEnd": true
            },
            {
                "type": "narrative",
                "text": "They look at you, stunned by your blatant interruption, but they respect your confidence.",
                "characterId": "narrator",
                "isEnd": true
            }
        ]
    },
    {
        "id": "event_elena_forgery_1",
        "category": "storyline",
        "title": "Elena's Warning",
        "requirements": {
            "intel": 3
        },
        "npcId": "elena_ross",
        "steps": [
            {
                "type": "narrative",
                "text": "Elena Ross intercepts you outside her gallery. Her usual warmth is replaced by a tight expression.",
                "characterId": "elena_ross"
            },
            {
                "type": "narrative",
                "text": "\"I need to tell you something. That digital artist everyone's talking about? The certificates of authenticity don't match. I've seen this before.\"",
                "characterId": "elena_ross"
            },
            {
                "type": "choice",
                "text": "She glances around nervously. \"Will you help me investigate?\"",
                "choices": [
                    {
                        "label": "\"I'll dig into it. Who else knows?\"",
                        "nextStep": 3,
                        "statChange": {
                            "intel": 2
                        }
                    },
                    {
                        "label": "\"Not my problem, Elena. I'm here to make money.\"",
                        "nextStep": 4,
                        "statChange": {
                            "audacity": 1
                        }
                    }
                ]
            },
            {
                "type": "narrative",
                "text": "Elena relaxes slightly. \"Just us, for now. Meet me at the back room of the Wine Bar on 24th Street next week. I'll have documents.\"",
                "characterId": "elena_ross",
                "isEnd": true
            },
            {
                "type": "narrative",
                "text": "Elena's face hardens. \"Fine. But when this breaks, don't say I didn't warn you.\" She disappears back into the gallery.",
                "characterId": "elena_ross",
                "isEnd": true
            }
        ]
    },
    {
        "id": "event_elena_forgery_2",
        "category": "storyline",
        "title": "The Wine Bar Documents",
        "requirements": {},
        "npcId": "elena_ross",
        "steps": [
            {
                "type": "narrative",
                "text": "The back room of the Wine Bar is dim and smells of old cork. Elena is already there with a manila envelope.",
                "characterId": "narrator"
            },
            {
                "type": "narrative",
                "text": "\"Provenance records for six works. Three of them list the same fictional gallery in Prague. They're manufacturing histories.\"",
                "characterId": "elena_ross"
            },
            {
                "type": "choice",
                "text": "She slides the envelope toward you.",
                "choices": [
                    {
                        "label": "Take the documents and study them.",
                        "nextStep": 3,
                        "statChange": {
                            "intel": 3
                        }
                    },
                    {
                        "label": "Photograph them and pass to your contacts.",
                        "nextStep": 4,
                        "statChange": {
                            "access": 2
                        }
                    }
                ]
            },
            {
                "type": "narrative",
                "text": "You pocket the envelope. The names on these documents lead somewhere deep. Time to follow the trail.",
                "characterId": "narrator",
                "isEnd": true
            },
            {
                "type": "narrative",
                "text": "Your phone buzzes all week. Three different contacts confirm the Prague gallery doesn't exist. The net is tightening.",
                "characterId": "narrator",
                "isEnd": true
            }
        ]
    },
    {
        "id": "event_elena_forgery_climax",
        "category": "storyline",
        "title": "The Forgery Ring Exposed",
        "requirements": {
            "access": 8
        },
        "npcId": "elena_ross",
        "steps": [
            {
                "type": "narrative",
                "text": "A headline in ArtNews: \"Chelsea Forgery Ring Busted — Six Galleries Under Investigation.\" Your phone won't stop ringing.",
                "characterId": "narrator"
            },
            {
                "type": "narrative",
                "text": "Elena calls first. \"We did it. The FBI raided their storage unit last night. Forty-two faked works. You should have seen their faces.\"",
                "characterId": "elena_ross"
            },
            {
                "type": "choice",
                "text": "She pauses. \"There's going to be a void in the market now. Collectors need new sources they can trust.\"",
                "choices": [
                    {
                        "label": "\"Let's fill that void. Together.\"",
                        "nextStep": 3,
                        "statChange": {
                            "reputation": 10,
                            "access": 5
                        }
                    },
                    {
                        "label": "\"I'll buy up the panic-sold inventory at discount.\"",
                        "nextStep": 4,
                        "statChange": {
                            "audacity": 5,
                            "intel": 3
                        }
                    }
                ]
            },
            {
                "type": "narrative",
                "text": "Elena smiles for the first time in weeks. \"Partners in legitimacy. I like the sound of that.\" Your reputation soars.",
                "characterId": "elena_ross",
                "isEnd": true
            },
            {
                "type": "narrative",
                "text": "While others panic, you negotiate. Three major works at 40% below market. Ruthless, but profitable. Elena won't forget this.",
                "characterId": "narrator",
                "isEnd": true
            }
        ]
    },
    {
        "id": "event_vandermeer_scheme_1",
        "category": "storyline",
        "title": "Vandermeer's Proposition",
        "requirements": {
            "audacity": 5
        },
        "npcId": "charles_vandermeer",
        "steps": [
            {
                "type": "narrative",
                "text": "A black car pulls up beside you on West 26th Street. The window rolls down. Charles Vandermeer.",
                "characterId": "narrator"
            },
            {
                "type": "narrative",
                "text": "\"Get in. I want to show you something.\" He doesn't wait for an answer. The door is already open.",
                "characterId": "charles_vandermeer"
            },
            {
                "type": "choice",
                "text": "Inside the car, he shows you images on his phone. Fifteen works by an artist you've never heard of.",
                "choices": [
                    {
                        "label": "\"Who is this? The work is extraordinary.\"",
                        "nextStep": 3,
                        "statChange": {
                            "taste": 2
                        }
                    },
                    {
                        "label": "\"What's the play, Charles? I want the numbers.\"",
                        "nextStep": 4,
                        "statChange": {
                            "intel": 2
                        }
                    }
                ]
            },
            {
                "type": "narrative",
                "text": "\"Nobody. Yet. That's the point. I'm buying the entire market before anyone knows the name. You want in?\" He smirks.",
                "characterId": "charles_vandermeer",
                "isEnd": true
            },
            {
                "type": "narrative",
                "text": "\"Smart. Average cost basis: $8,000 per work. I plan to sell at $200,000 each within 18 months. The math works if we control supply.\"",
                "characterId": "charles_vandermeer",
                "isEnd": true
            }
        ]
    },
    {
        "id": "event_vandermeer_scheme_2",
        "category": "storyline",
        "title": "The Pump",
        "requirements": {},
        "npcId": "charles_vandermeer",
        "steps": [
            {
                "type": "narrative",
                "text": "Magazine covers. Instagram posts from A-listers. A glowing review in Hyperallergic. Vandermeer's machine is running.",
                "characterId": "narrator"
            },
            {
                "type": "narrative",
                "text": "\"Phase two complete.\" He texts you a screenshot: secondary market prices already up 400%. \"The artist doesn't even know what's coming.\"",
                "characterId": "charles_vandermeer"
            },
            {
                "type": "choice",
                "text": "Your phone buzzes with offers from collectors wanting to buy your allocation.",
                "choices": [
                    {
                        "label": "Hold. The price hasn't peaked yet.",
                        "nextStep": 3,
                        "statChange": {
                            "intel": 3
                        }
                    },
                    {
                        "label": "Sell half now to lock in gains.",
                        "nextStep": 4,
                        "statChange": {
                            "audacity": 2
                        }
                    }
                ]
            },
            {
                "type": "narrative",
                "text": "\"Patient. I like that.\" Vandermeer nods approvingly. The prices keep climbing. But how long can this last?",
                "characterId": "charles_vandermeer",
                "isEnd": true
            },
            {
                "type": "narrative",
                "text": "You bank $120,000 on the partial sale. Smart money, but Vandermeer looks at you like you just blinked in a poker game.",
                "characterId": "narrator",
                "isEnd": true
            }
        ]
    },
    {
        "id": "event_vandermeer_scheme_climax",
        "category": "storyline",
        "title": "The Dump",
        "requirements": {
            "intel": 6
        },
        "npcId": "charles_vandermeer",
        "steps": [
            {
                "type": "narrative",
                "text": "It happens overnight. Vandermeer dumps his entire position — 15 works — through three different auction houses simultaneously.",
                "characterId": "narrator"
            },
            {
                "type": "narrative",
                "text": "The market price collapses 70% in a single day. Collectors are furious. The artist is devastated. Vandermeer is unreachable.",
                "characterId": "narrator"
            },
            {
                "type": "choice",
                "text": "Your remaining holdings are cratering. What do you do?",
                "choices": [
                    {
                        "label": "Cut losses. Sell everything and distance yourself from Vandermeer.",
                        "nextStep": 3,
                        "statChange": {
                            "reputation": -5
                        }
                    },
                    {
                        "label": "Double down. Buy the crash. If the art is real, it'll recover.",
                        "nextStep": 4,
                        "statChange": {
                            "taste": 5,
                            "audacity": 5
                        }
                    }
                ]
            },
            {
                "type": "narrative",
                "text": "You walk away with your capital mostly intact and your reputation slightly singed. The art world has a long memory.",
                "characterId": "narrator",
                "isEnd": true
            },
            {
                "type": "narrative",
                "text": "Eighteen months later, the artist wins the Turner Prize. Your contrarian bet pays off 10x. Vandermeer texts you: \"Not bad.\"",
                "characterId": "narrator",
                "isEnd": true
            }
        ]
    },
    {
        "id": "elena_gallery_chat",
        "category": "social",
        "title": "Gallery Opening with Elena",
        "requirements": {},
        "npcInvolved": "npc_elena",
        "steps": [
            {
                "type": "dialogue",
                "speaker": "Elena Ross",
                "text": "You've been making waves. I have a piece in the back that might interest someone with your eye."
            },
            {
                "type": "dialogue",
                "speaker": "Elena Ross",
                "text": "A stunning abstract by Kai Renard — fresh from Basel. Chromatic Drift. The colors are extraordinary in person."
            },
            {
                "type": "choice",
                "text": "Elena gestures toward the back room.",
                "choices": [
                    {
                        "label": "\"Let's talk price.\"",
                        "triggerHaggle": true,
                        "npcInvolved": "npc_elena",
                        "effects": {
                            "cash": -15000
                        },
                        "work": {
                            "id": "elena_chromatic_drift",
                            "title": "Chromatic Drift",
                            "artist": "Kai Renard",
                            "year": "2025",
                            "medium": "Acrylic on canvas"
                        }
                    },
                    {
                        "label": "\"Beautiful, but I'll pass for now.\"",
                        "outcome": "Elena nods gracefully. \"The door's always open.\"",
                        "statChange": {
                            "access": 1
                        }
                    }
                ]
            }
        ]
    },
    {
        "id": "margaux_studio_visit",
        "category": "social",
        "title": "Margaux's Studio Find",
        "requirements": {},
        "npcInvolved": "npc_margaux",
        "steps": [
            {
                "type": "dialogue",
                "speaker": "Margaux Villiers",
                "text": "I was at this absolutely unhinged studio visit last week. Post-internet meets oil painting. Chaotic. Brilliant."
            },
            {
                "type": "dialogue",
                "speaker": "Margaux Villiers",
                "text": "I managed to acquire a piece before anyone else caught on. Digital Ephemera by Suki Tanaka. It's... well, you should see it."
            },
            {
                "type": "choice",
                "text": "Margaux tilts her head, gauging your interest.",
                "choices": [
                    {
                        "label": "\"I want it. Name your price.\"",
                        "triggerHaggle": true,
                        "npcInvolved": "npc_margaux",
                        "effects": {
                            "cash": -8000
                        },
                        "work": {
                            "id": "margaux_digital_ephemera",
                            "title": "Digital Ephemera",
                            "artist": "Suki Tanaka",
                            "year": "2025",
                            "medium": "Mixed media / digital print"
                        }
                    },
                    {
                        "label": "\"Interesting. Tell me more about the artist.\"",
                        "outcome": "You file away the name for later research. Suki Tanaka — one to watch.",
                        "statChange": {
                            "intel": 2
                        }
                    }
                ]
            }
        ]
    },
    {
        "id": "julian_flip_deal",
        "category": "market",
        "title": "Julian's Quick Flip",
        "requirements": {},
        "npcInvolved": "npc_julian",
        "steps": [
            {
                "type": "dialogue",
                "speaker": "Julian Vance",
                "text": "Yo. I just picked up this piece at auction for way under estimate. The market's sleeping on this one."
            },
            {
                "type": "dialogue",
                "speaker": "Julian Vance",
                "text": "Untitled JPEG #7 by dxtr.eth. The NFT hype is dead but the underlying art? Chef's kiss. Floor price is about to go parabolic."
            },
            {
                "type": "choice",
                "text": "Julian pulls up the piece on his phone.",
                "choices": [
                    {
                        "label": "\"Alright, let's haggle.\"",
                        "triggerHaggle": true,
                        "npcInvolved": "npc_julian",
                        "effects": {
