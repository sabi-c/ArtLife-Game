# ─────────────────────────────────────────────────────────────
# AG Manager — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────
# API key required for all /api/* endpoints.
# Open the web UI as: http://localhost:3737/?key=YOUR_KEY
# Leave blank for unprotected local-only dev use.
AG_MANAGER_KEY=change-me-to-a-secure-random-string

# ── Server Port ───────────────────────────────────────────────
# Port the AG Manager web UI and API run on (default: 3737)
AG_MANAGER_PORT=3737

# ── Antigravity IDE ───────────────────────────────────────────
# Path to the Antigravity binary on macOS.
# If 'antigravity' is in your PATH, leave this as-is.
# Otherwise set the full path, e.g.:
#   /Applications/Antigravity.app/Contents/MacOS/antigravity
AG_PATH=antigravity

# Full path to the project workspace to open in Antigravity
AG_WORKSPACE=/Users/YOUR_USERNAME/ArtLife-Game

# Chrome DevTools Protocol port — must match what phone_chat expects
# Default is 9000. Change both here and in phone_chat's config if needed.
AG_CDP_PORT=9000

# ── Phone Chat Integration ────────────────────────────────────
# Full path to your cloned antigravity_phone_chat repo.
# Leave blank to disable phone_chat auto-start.
# Clone it from: https://github.com/krishnakanthb13/antigravity_phone_chat
PHONE_CHAT_DIR=/Users/YOUR_USERNAME/antigravity_phone_chat

# ── SMS via Twilio (optional) ─────────────────────────────────
# Leave all three blank to disable SMS. You can still use the web UI.
#
# Setup steps:
#   1. Create a free Twilio account at https://twilio.com
#   2. Get a phone number (~$1/month)
#   3. Set that number's webhook to POST https://YOUR_SERVER/sms
#   4. Fill in the values below

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Your personal mobile number — only texts FROM this number will be accepted.
# Format: +15551234567 (E.164 format)
ALLOWED_PHONE=+1
